{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "./types/expo-env.d.ts",
    "./types/nativewind-env.d.ts",
    "nativewind-env.d.ts",
    "expo-env.d.ts"
  ]
}
